ENV="development"

FRONTEND_HOST_PORT="3000"
FRONTEND_CONTAINER_PORT="3000"

FRONTEND_NEXT_PUBLIC_SITE_URL="http://localhost:3000"
FRONTEND_AUTH_SERVICE_URL="http://auth-grpc-gateway:8081"
FRONTEND_USER_SERVICE_URL="http://user-grpc-gateway:8082"
FRONTEND_WORKOUT_SERVICE_URL="http://workout-grpc-gateway:8083"

AUTH_SERVER_HOST="auth-server"
AUTH_SERVER_CONTAINER_PORT="50051"
AUTH_SERVER_HOST_PORT="50051"

AUTH0_BASE_URL=""
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_AUDIENCE=""

AUTH_GRPC_GATEWAY_HOST="auth-grpc-gateway"
AUTH_GRPC_GATEWAY_CONTAINER_PORT="8081"
AUTH_GRPC_GATEWAY_HOST_PORT="8081"

USER_SERVER_HOST="user-server"
USER_SERVER_CONTAINER_PORT="50052"
USER_SERVER_HOST_PORT="50052"

USER_DB_HOST="user-db"
USER_DB_USER="user"
USER_DB_PASSWORD="password"
USER_DB_NAME="user_db"
USER_DB_CONTAINER_PORT="5432"
USER_DB_HOST_PORT="5432"
USER_DB_SSL_MODE="disable"

USER_GRPC_GATEWAY_HOST="user-grpc-gateway"
USER_GRPC_GATEWAY_CONTAINER_PORT="8082"
USER_GRPC_GATEWAY_HOST_PORT="8082"

WORKOUT_SERVER_HOST="workout-server"
WORKOUT_SERVER_CONTAINER_PORT="50053"
WORKOUT_SERVER_HOST_PORT="50053"

WORKOUT_DB_HOST="workout-db"
WORKOUT_DB_USER="user"
WORKOUT_DB_PASSWORD="password"
WORKOUT_DB_NAME="workout_db"
WORKOUT_DB_CONTAINER_PORT="5432"
WORKOUT_DB_HOST_PORT="5433"
WORKOUT_DB_SSL_MODE="disable"

WORKOUT_GRPC_GATEWAY_HOST="workout-grpc-gateway"
WORKOUT_GRPC_GATEWAY_CONTAINER_PORT="8083"
WORKOUT_GRPC_GATEWAY_HOST_PORT="8083"

LOGGING_SERVER_HOST="logging-server"
LOGGING_SERVER_CONTAINER_PORT="8000"
LOGGING_SERVER_HOST_PORT="8000"

LOGGING_DB_HOST="logging-db"
LOGGING_DB_USER="user"
LOGGING_DB_PASSWORD="password"
LOGGING_DB_NAME="logging_db"
LOGGING_DB_CONTAINER_PORT="5432"
LOGGING_DB_HOST_PORT="5434"
LOGGING_DB_SSL_MODE="disable"
LOGGING_DB_URL="postgresql://${LOGGING_DB_USER}:${LOGGING_DB_PASSWORD}@${LOGGING_DB_HOST}:${LOGGING_DB_CONTAINER_PORT}/${LOGGING_DB_NAME}?sslmode=${LOGGING_DB_SSL_MODE}"
